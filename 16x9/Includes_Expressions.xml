<?xml version="1.0" encoding="UTF-8"?>
<includes>
	<!-- Menu -->
	<expression name="HasVerticalMenuWithExtended">String.IsEqual(Skin.String(MainMenu.Layout),vertical) + [String.Contains(Container(9000).ListItem.Property(widgetStyle),Extended) + ControlGroup(90010).HasFocus] | [String.Contains(Container(9000).ListItem.Property(widgetStyle.2),Extended) + ControlGroup(90020).HasFocus]</expression>
	<expression name="WidgetFanartVisible">[[String.IsEmpty(Container(9000).ListItem.Property(widgetDisableFanart)) + ControlGroup(90010).HasFocus] | [String.IsEmpty(Container(9000).ListItem.Property(widgetDisableFanart.2)) + ControlGroup(90020).HasFocus]]</expression>
	<expression name="CenterMainMenu">Skin.HasSetting(centermainmenu) + !String.IsEqual(Skin.String(MainMenu.Layout),vertical)</expression>
	<!-- Info Dialog Plots -->
	<expression name="HasInfoPlotArt">[String.IsEqual(ListItem.DBTYPE,movie) + Skin.HasSetting(discartoninfo) + !String.IsEmpty(ListItem.Art(discart))] | [String.IsEqual(ListItem.DBTYPE,tvshow) + Skin.HasSetting(CharacterOnInfo) + !String.IsEmpty(ListItem.Art(clearart))] | [String.IsEqual(ListItem.DBTYPE,episode) | String.IsEqual(ListItem.DBTYPE,season)] + Skin.HasSetting(CharacterOnInfo) + !String.IsEmpty(ListItem.Art(tvshow.clearart))</expression>
	<expression name="NoInfoPlotArt">[String.IsEqual(ListItem.DBTYPE,movie) + [!Skin.HasSetting(discartoninfo) | String.IsEmpty(ListItem.Art(discart))]] | [String.IsEqual(ListItem.DBTYPE,tvshow) + [!Skin.HasSetting(CharacterOnInfo) | String.IsEmpty(ListItem.Art(clearart))]] | [[String.IsEqual(ListItem.DBTYPE,episode) | String.IsEqual(ListItem.DBTYPE,season)] + [!Skin.HasSetting(CharacterOnInfo) | String.IsEmpty(ListItem.Art(tvshow.clearart))]] | String.IsEqual(ListItem.DBTYPE,set) | String.IsEqual(ListItem.DBTYPE,musicvideo)</expression>
	<expression name="HasCustomInfoPlotArt">[String.IsEqual(Window(Home).Property(item_dbtype),movie) + Skin.HasSetting(discartoninfo) + !String.IsEmpty(Container(4800).ListItem.Art(discart))] | [String.IsEqual(Window(Home).Property(item_dbtype),tvshow) + Skin.HasSetting(CharacterOnInfo) + !String.IsEmpty(Container(4800).ListItem.Art(clearart))] | [String.IsEqual(Window(Home).Property(item_dbtype),episode) | String.IsEqual(Window(Home).Property(item_dbtype),season)] + Skin.HasSetting(CharacterOnInfo) + !String.IsEmpty(Container(4800).ListItem.Art(tvshow.clearart))</expression>
	<expression name="NoCustomInfoPlotArt">[String.IsEqual(Window(Home).Property(item_dbtype),movie) + [!Skin.HasSetting(discartoninfo) | String.IsEmpty(Container(4800).ListItem.Art(discart))]] | [String.IsEqual(Window(Home).Property(item_dbtype),tvshow) + [!Skin.HasSetting(CharacterOnInfo) | String.IsEmpty(Container(4800).ListItem.Art(clearart))]] | [[String.IsEqual(Window(Home).Property(item_dbtype),episode) | String.IsEqual(Window(Home).Property(item_dbtype),season)] + [!Skin.HasSetting(CharacterOnInfo) | String.IsEmpty(Container(4800).ListItem.Art(tvshow.clearart))]]</expression>
	<!-- Rating Mediaflags -->
	<expression name="HasRTCriticRating">[!String.IsEmpty(Window(Home).Property(SkinInfo.ListItem.Rating.Tomatoes.Percent)) | !String.IsEmpty(Window(Home).Property(SkinInfo.Online.Rating.Tomatoes.Percent))] + [Container.Content(movies) | Container.Content(tvshows)] + !Skin.HasSetting(DisableFlag_RTCritic)</expression>
	<expression name="HasRTAudienceRating">[!String.IsEmpty(Window(Home).Property(SkinInfo.ListItem.Rating.Popcorn.Percent)) | !String.IsEmpty(Window(Home).Property(SkinInfo.Online.Rating.Popcorn.Percent))] + [Container.Content(movies) | Container.Content(tvshows)] + !Skin.HasSetting(DisableFlag_RTAudience)</expression>
	<expression name="HasTMDbRating">[!String.IsEmpty(Window(Home).Property(SkinInfo.Online.Rating.tmdb)) | !String.IsEmpty(Window(Home).Property(SkinInfo.ListItem.Rating.tmdb))] + !Container.Content(seasons) + !Skin.HasSetting(DisableFlag_TMDb)</expression>
	<expression name="HasTraktRating">[!String.IsEmpty(Window(Home).Property(SkinInfo.Online.Rating.trakt)) | !String.IsEmpty(Window(Home).Property(SkinInfo.ListItem.Rating.trakt))] + !Container.Content(seasons) + !Skin.HasSetting(DisableFlag_Trakt)</expression>
	<expression name="HasIMDbRating">[!String.IsEmpty(Window(Home).Property(SkinInfo.Online.Rating.imdb)) | !String.IsEmpty(Window(Home).Property(SkinInfo.ListItem.Rating.imdb))] + !Container.Content(seasons) + !Skin.HasSetting(DisableFlag_IMDb)</expression>
	<expression name="NoRTCriticRating">[String.IsEmpty(Window(Home).Property(SkinInfo.ListItem.Rating.Tomatoes.Percent)) + String.IsEmpty(Window(Home).Property(SkinInfo.Online.Rating.Tomatoes.Percent))] | [!Container.Content(movies) + !Container.Content(tvshows)] | Skin.HasSetting(DisableFlag_RTCritic)</expression>
	<expression name="NoRTAudienceRating">[String.IsEmpty(Window(Home).Property(SkinInfo.ListItem.Rating.Popcorn.Percent)) + String.IsEmpty(Window(Home).Property(SkinInfo.ListItem.Rating.Popcorn))] | [!Container.Content(movies) + !Container.Content(tvshows)] | Skin.HasSetting(DisableFlag_RTAudience)</expression>
	<expression name="NoTMDbRating">[String.IsEmpty(Window(Home).Property(SkinInfo.Online.Rating.tmdb)) + String.IsEmpty(Window(Home).Property(SkinInfo.ListItem.Rating.tmdb))] | Container.Content(seasons) | Skin.HasSetting(DisableFlag_TMDb)</expression>
	<expression name="NoTraktRating">[String.IsEmpty(Window(Home).Property(SkinInfo.Online.Rating.trakt)) + String.IsEmpty(Window(Home).Property(SkinInfo.ListItem.Rating.trakt))] | Container.Content(seasons) | Skin.HasSetting(DisableFlag_Trakt)</expression>
	<expression name="NoIMDbRating">[String.IsEmpty(Window(Home).Property(SkinInfo.Online.Rating.imdb)) + String.IsEmpty(Window(Home).Property(SkinInfo.ListItem.Rating.imdb))] | Container.Content(seasons) | Skin.HasSetting(DisableFlag_IMDb)</expression>
	<expression name="HasOnlyOneRating">[$EXP[HasRTCriticRating] + $EXP[NoRTAudienceRating] + $EXP[NoTMDbRating] + $EXP[NoTraktRating] + $EXP[NoIMDbRating]] | [$EXP[NoRTCriticRating] + $EXP[HasRTAudienceRating] + $EXP[NoTMDbRating] + $EXP[NoTraktRating] + $EXP[NoIMDbRating]] | [$EXP[NoRTCriticRating] + $EXP[NoRTAudienceRating] + $EXP[HasTMDbRating] + $EXP[NoTraktRating] + $EXP[NoIMDbRating]] | [$EXP[NoRTCriticRating] + $EXP[NoRTAudienceRating] + $EXP[NoTMDbRating] + $EXP[HasTraktRating] + $EXP[NoIMDbRating]] | [$EXP[NoRTCriticRating] + $EXP[NoRTAudienceRating] + $EXP[NoTMDbRating] + $EXP[NoTraktRating] + $EXP[HasIMDbRating]]</expression>
	<!-- Content -->
	<expression name="IsTVShowOrSeason">Container.Content(tvshows) | Container.Content(seasons)</expression>
	<!-- Container -->
	<expression name="ContainerNotScrolling">!Container.OnNext + !Container.OnPrevious</expression>
	<expression name="CanFilterSimple">Container.CanFilter + !Container.CanFilterAdvanced</expression>
	<!-- Misc -->
	<expression name="StartupIntroActive">[!String.IsEmpty(Skin.String(StartupIntro)) + String.IsEmpty(Window(Home).Property(Playing.StartupIntro))] | String.IsEmpty(Skin.String(StartupIntro))</expression>
	<expression name="HasTop250">!String.IsEmpty(ListItem.Top250) + Integer.IsLessOrEqual(ListItem.Top250,250)</expression>
	<expression name="Posters56DisableOverlay">[!String.IsEmpty(Skin.String(56.Movies.DisableOverlay)) + Container.Content(movies)] | [!String.IsEmpty(Skin.String(56.TV.DisableOverlay)) + Container.Content(tvshows)] | [!String.IsEmpty(Skin.String(56.Sets.DisableOverlay)) + Container.Content(sets)] | [!String.IsEmpty(Skin.String(56.Seasons.DisableOverlay)) + Container.Content(seasons)]</expression>
</includes>
